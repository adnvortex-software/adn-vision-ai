# ADN LYNX AI - Variables de entorno
# Copiar a .env.local para desarrollo

# ══════════════════════════════════════════════════════════════════
# FIREBASE CONFIGURATION
# Obtener de Firebase Console > Project Settings > Your apps
# ══════════════════════════════════════════════════════════════════

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ══════════════════════════════════════════════════════════════════
# ENVIRONMENT
# development | staging | production
# ══════════════════════════════════════════════════════════════════

VITE_ENV=development

# ══════════════════════════════════════════════════════════════════
# FEATURE FLAGS (opcionales)
# ══════════════════════════════════════════════════════════════════

# Habilitar logs de debug
VITE_ENABLE_DEBUG=false

# Usar auth mockeado (para desarrollo sin Firebase)
VITE_MOCK_AUTH=false

# Habilitar DevTools de React Query
VITE_ENABLE_QUERY_DEVTOOLS=true
