rules_version = '2';

/**
 * ADN VISION AI - Firestore Security Rules
 *
 * DEVELOPMENT MODE: Permissive rules for testing
 * TODO: Replace with production rules before launch
 *
 * Deploy with: firebase deploy --only firestore:rules
 */

service cloud.firestore {
  match /databases/{database}/documents {
    // ============================================
    // DEVELOPMENT: Allow all authenticated users
    // ============================================

    // Allow authenticated users to create their own user document
    // This enables the bootstrap/seed process
    match /usuarios/{userId} {
      allow read, write: if request.auth != null;
    }

    // Allow authenticated users full access to all collections
    match /clientes/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /buses/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /eventos/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /conteos/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /conteosDiarios/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /catalogoNovedades/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /reportes/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /auditLog/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
