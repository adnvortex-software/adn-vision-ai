rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Profile photos - users can read/write their own
    match /usuarios/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Client logos - authenticated users can read, admins can write
    match /clientes/{clienteId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Bus images/captures - authenticated users can read/write
    match /buses/{busId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Event images - authenticated users can read/write
    match /eventos/{eventoId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // General uploads - authenticated users
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
